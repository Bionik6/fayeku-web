APP_NAME=Fayeku
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (fallback email pour notifications clients sans WhatsApp)
# En prod/staging : mets MAIL_MAILER=resend et renseigne la clé.
# https://resend.com/api-keys
RESEND_API_KEY=

# Emails de l'équipe Fayeku qui reçoivent les alertes "nouveau lead cabinet".
# Séparés par des virgules. Vide en local = aucune notification équipe.
FAYEKU_ADMIN_EMAILS=

# URL publique du logo affiché dans l'en-tête des emails. Doit être joignable
# depuis Internet (Gmail proxie les images via Google). En local, pointer sur
# l'URL prod (https://fayeku.sn/apple-touch-icon.png) pour un rendu fidèle.
# Si vide, fallback automatique sur ${APP_URL}/apple-touch-icon.png.
MAIL_LOGO_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WhatsApp Business Cloud API (Meta direct)
# Business Manager → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
# WABA id (Business Account) — requis pour récupérer les bodies des templates
# approuvés via Graph API et alimenter l'aperçu côté app.
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
# TTL du cache local des bodies Meta, en minutes (défaut : 24h).
WHATSAPP_TEMPLATES_CACHE_MINUTES=1440

# ─── OTP (vérification téléphone SME) ───
# Canal de livraison : `whatsapp` (défaut, en attendant la validation Orange IAM)
# ou `sms` (Orange SMS, à activer une fois le compte validé et les credentials remplis ci-dessous).
OTP_CHANNEL=whatsapp
# Durée de validité d'un code OTP, en minutes.
OTP_EXPIRY_MINUTES=10
# Nombre max de tentatives de vérification avant invalidation du code.
OTP_MAX_ATTEMPTS=3
# Code de contournement local uniquement (laisser vide en prod).
# Si défini, ce code remplace tout OTP généré — utile pour les tests manuels sans SMS/WhatsApp.
OTP_BYPASS_CODE=

# ─── Orange SMS API (OTP via SMS) ───
# Doc : https://developer.orange.com/apis/sms/getting-started
# Récupère client_id et client_secret dans "MyApps" du portail Orange Developer.
ORANGE_SMS_BASE_URL=https://api.orange.com
ORANGE_SMS_CLIENT_ID=
ORANGE_SMS_CLIENT_SECRET=
# Sender address au format `tel:+CCNNNN` selon le pays du bundle acheté :
#   - Côte d'Ivoire  : tel:+2250000
#   - Sénégal        : tel:+2210000
#   - Mali           : tel:+2230000
#   - Burkina Faso   : tel:+2260000
#   (liste complète dans la doc Orange)
ORANGE_SMS_SENDER_ADDRESS=
# Nom d'expéditeur affiché (max 11 caractères alphanumériques + espaces, pas de spéciaux).
# IMPORTANT : laisser VIDE tant que tu n'as pas fait approuver un sender name
# personnalisé par le support Orange (dans le portail : Configure SMS > Authorized
# senders). Si rempli avec un nom non approuvé, Orange consomme le bundle mais
# ne livre pas le SMS au destinataire.
ORANGE_SMS_SENDER_NAME=
